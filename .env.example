# =========================================================================
# Instituto Dr. Igor — Environment Template
# Copie este arquivo para `.env` e preencha. NUNCA commite o `.env` real.
# Veja AGENTS.md e docs/ENVIRONMENT.md para a referência completa.
# =========================================================================

# ----- Igor / Flags de proteção -----
IGOR_ENV=staging                          # staging | production
IGOR_DRY_RUN=true                         # se true, IGOR_10/IGOR_13 não chama sendText
ALLOW_REAL_WHATSAPP_SEND=false            # destrava chamadas Evolution sendText
ALLOW_PRODUCTION_MUTATIONS=false          # destrava mutações em n8n/Chatwoot

# ----- Horários e timezone -----
TIMEZONE=America/Sao_Paulo
AFTER_HOURS_START=18:30                   # IA receptiva começa
AFTER_HOURS_END=07:30                     # IA receptiva termina
CAMPAIGN_SEND_WINDOW_START=09:00          # campanha pode disparar a partir de
CAMPAIGN_SEND_WINDOW_END=17:30            # campanha para de disparar
CAMPAIGN_DAILY_LIMIT=20                   # máx de envios por dia (Dia 1 → 20 → 50 → 100)
CAMPAIGN_PER_MINUTE_LIMIT=1               # throttle de envio
PROMO_PRICE=600.00
REGULAR_PRICE=800.00
PROMO_VALID_UNTIL=

# ----- n8n -----
N8N_BASE_URL=
N8N_API_KEY=
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_URL=

# ----- Chatwoot -----
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_INBOX_ID=                        # preencher depois que Fase 3 criar
CHATWOOT_HUMAN_TEAM_ID=                   # preencher depois que Fase 3 criar
CHATWOOT_HUMAN_ASSIGNEE_ID=               # preencher depois que Fase 3 criar
CHATWOOT_HUMAN_AGENT_NAME=                # preencher depois que Fase 3 criar

# ----- Evolution API -----
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# ----- Supabase Cloud -----
SUPABASE_URL=
SUPABASE_HOST=
SUPABASE_PROJECT_ID=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_CONNECTION_STRING=            # pooler conhecido como instável — não confiar

# ----- Redis (vazio: Igor usa Redis embarcado no n8n via credential interna) -----
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ----- LLM Providers -----
OPENAI_API_KEY=
GEMINI_API_KEY=

# ----- LangSmith (opcional) -----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_CALLBACKS_BACKGROUND=true
LANGCHAIN_ENDPOINT=
LANGCHAIN_PROJECT=
LANGCHAIN_API_KEY=

# ----- Testes -----
TEST_WHATSAPP_NUMBER=                     # número de teste autorizado
