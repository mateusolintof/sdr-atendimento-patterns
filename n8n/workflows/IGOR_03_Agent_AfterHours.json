    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nreturn items.map(item => {\n  const j = item.json || {};\n  const phone = (j.phone === undefined || j.phone === null || j.phone === '') ? null : String(j.phone);\n  const normalizedText = (j.normalized_text === undefined || j.normalized_text === null) ? '' : String(j.normalized_text);\n  const convIdRaw = j.chatwoot_conversation_id;\n  const convId = (convIdRaw === undefined || convIdRaw === null || convIdRaw === '') ? null : parseInt(convIdRaw, 10);\n  const inboxIdRaw = j.chatwoot_inbox_id;\n  const inboxId = (inboxIdRaw === undefined || inboxIdRaw === null || inboxIdRaw === '') ? 1 : parseInt(inboxIdRaw, 10);\n  const contactIdRaw = j.chatwoot_contact_id;\n  const contactId = (contactIdRaw === undefined || contactIdRaw === null || contactIdRaw === '') ? null : parseInt(contactIdRaw, 10);\n  const sf = (j.safety_flags && typeof j.safety_flags === 'object') ? j.safety_flags : {};\n  const safetyFlags = {\n    clinical: sf.clinical === true,\n    sensitive_image: sf.sensitive_image === true,\n    unknown_media: sf.unknown_media === true\n  };\n  const shouldHandoff = j.should_handoff === true;\n  const handoffReason = (j.handoff_reason === undefined || j.handoff_reason === null || j.handoff_reason === '') ? null : String(j.handoff_reason);\n  const testRunId = (j.test_run_id === undefined || j.test_run_id === null) ? null : String(j.test_run_id);\n  const forceHandoff = shouldHandoff || safetyFlags.clinical || safetyFlags.sensitive_image || safetyFlags.unknown_media;\n  const resolvedReason = handoffReason || (safetyFlags.clinical ? 'documento_clinico_sensivel' : (safetyFlags.sensitive_image ? 'midia_sensivel' : (safetyFlags.unknown_media ? 'midia_desconhecida' : 'unspecified')));\n  return {\n    json: {\n      phone,\n      normalized_text: normalizedText,\n      chatwoot_conversation_id: convId,\n      chatwoot_inbox_id: inboxId,\n      chatwoot_contact_id: contactId,\n      safety_flags: safetyFlags,\n      should_handoff: shouldHandoff,\n      handoff_reason: resolvedReason,\n      force_handoff: forceHandoff,\n      test_run_id: testRunId\n    }\n  };\n});"
      },
