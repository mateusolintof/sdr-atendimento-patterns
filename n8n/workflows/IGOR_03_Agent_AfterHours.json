        "jsCode": "const v = $('Validate Payload').first().json;\nconst payload = {\n  phone: v.phone,\n  reason: v.handoff_reason,\n  safety_flags: v.safety_flags,\n  should_handoff: v.should_handoff,\n  test_run_id: v.test_run_id\n};\nreturn [{\n  json: {\n    routed_payload_json: JSON.stringify(payload),\n    chatwoot_conversation_id: v.chatwoot_conversation_id,\n    phone: v.phone,\n    test_run_id: v.test_run_id\n  }\n}];"
